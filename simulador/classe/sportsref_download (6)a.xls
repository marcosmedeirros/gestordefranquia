      </tr>
            
      <tr>
         <th aria-label="Rk" data-stat="ranker" scope="col" class="ranker poptip sort_default_asc show_partial_when_sorting center" data-tip="Rank">Rk</th>
         <th aria-label="Pk" data-stat="pick_overall" scope="col" class=" poptip sort_default_asc center" data-tip="Overall Pick" data-over-header="Round 1">Pk</th>
