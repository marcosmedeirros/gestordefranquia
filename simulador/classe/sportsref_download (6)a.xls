      <tr class="over_header"><th class="not_sticky"></th><th style="left: 0px; position: sticky; text-align: right; z-index: 19;"></th><th class="not_sticky"></th>
         <th aria-label="" data-stat="header_draft" colspan="2" class=" over_header center" style="left: -190px; position: sticky; text-align: right; z-index: 17; border-right: 1px solid rgb(148, 150, 152);">Round 1</th><th class="not_sticky"></th>
         <th aria-label="" data-stat="header_totals" colspan="5" class="over_header center not_sticky">Totals</th>
