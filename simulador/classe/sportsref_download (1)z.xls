         <th aria-label="Games" data-stat="g" scope="col" class=" poptip center" data-tip="Games" data-over-header="Totals">G</th>
         <th aria-label="Minutes Played" data-stat="mp" scope="col" class=" poptip center" data-tip="Minutes Played" data-over-header="Totals">MP</th>
         <th aria-label="Points" data-stat="pts" scope="col" class=" poptip center" data-tip="Points" data-over-header="Totals">PTS</th>
         <th aria-label="Total Rebounds" data-stat="trb" scope="col" class=" poptip center" data-tip="Total Rebounds" data-over-header="Totals">TRB</th>
         <th aria-label="Assists" data-stat="ast" scope="col" class=" poptip center" data-tip="Assists" data-over-header="Totals">AST</th>
         <th aria-label="Field Goal Percentage" data-stat="fg_pct" scope="col" class=" poptip center" data-tip="Field Goal Percentage" data-over-header="Shooting">FG%</th>
         <th aria-label="3-Point Field Goal Percentage" data-stat="fg3_pct" scope="col" class=" poptip center" data-tip="3-Point Field Goal Percentage" data-over-header="Shooting">3P%</th>
         <th aria-label="Free Throw Percentage" data-stat="ft_pct" scope="col" class=" poptip center" data-tip="Free Throw Percentage" data-over-header="Shooting">FT%</th>
         <th aria-label="Minutes Played Per Game" data-stat="mp_per_g" scope="col" class=" poptip center" data-tip="Minutes Played Per Game" data-over-header="Per Game">MP</th>
         <th aria-label="Points Per Game" data-stat="pts_per_g" scope="col" class=" poptip center" data-tip="Points Per Game" data-over-header="Per Game">PTS</th>
